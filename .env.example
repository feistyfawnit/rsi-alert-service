# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/rsi_alerts
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Notifications — Telegram (private)
# Setup:
#   1. Message @BotFather → /newbot → copy the token below
#   2. Each recipient must message the bot first (tap START)
#   3. Get their chat ID: curl https://api.telegram.org/bot{TOKEN}/getUpdates
#      Look for "chat":{"id":XXXXXXXX} in the response
# Multiple recipients: comma-separate the IDs e.g. 6633143916,987654321
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=recipient@example.com

# IG API (Phase 2 — unlocks DAX, FTSE, Gold, Oil, all indices)
# Demo URL: https://demo-api.ig.com/gateway/deal
# Live URL: https://api.ig.com/gateway/deal
IG_ENABLED=false
IG_API_KEY=your_ig_api_key
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_BASE_URL=https://demo-api.ig.com/gateway/deal

# Claude AI Enrichment (Phase 3 — optional, adds news context to signals)
# Cost: ~$2-5/month depending on signal frequency
# Get key at: https://console.anthropic.com
CLAUDE_ENABLED=false
CLAUDE_API_KEY=your_claude_api_key

# Finnhub (not recommended — free tier rate limits too low for real-time polling)
FINNHUB_API_KEY=

# Auto-Trading (Phase 4 — DO NOT ENABLE until 3+ months paper trading validated)
TRADING_AUTO_EXECUTION_ENABLED=false
TRADING_MAX_POSITION_PERCENT=2
TRADING_MAX_CONCURRENT_POSITIONS=2
TRADING_DAILY_LOSS_LIMIT_PERCENT=2
TRADING_REQUIRE_MANUAL_APPROVAL=true

# Anomaly Detection (Phase 5 — volume spikes + Polymarket odds shifts)
# Polymarket slugs must be verified at polymarket.com — they change as markets expire
ANOMALY_DETECTION_ENABLED=true

# Security — rename this to something unguessable to prevent strangers subscribing
# e.g. NTFY_TOPIC=rsi-alerts-x7k9m2p
# NTFY_TOPIC=rsi-alerts

# Server Port
PORT=8080
