# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/rsi_alerts
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Market Data APIs
FINNHUB_API_KEY=your_finnhub_api_key_here

# Notifications
